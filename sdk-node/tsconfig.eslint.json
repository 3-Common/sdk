{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "examples/**/*",
    "scripts/**/*",
    "*.config.ts",
    "*.config.js",
    "eslint.config.js"
  ],
  "exclude": ["dist", "node_modules", "coverage"]
}
