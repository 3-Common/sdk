# Env template for the live smoke test (scripts/live-smoke.ts).
#
# Copy this file to `.env` (which is gitignored) and fill in your values, then
# run the smoke test locally with:
#
#   yarn smoke:local
#
# The plain `yarn smoke` (used by CI) reads these from the process environment
# instead; see .github/workflows/live-smoke.yml.

# REQUIRED — a real API key for the host you want to smoke-test.
THREECOMMON_API_KEY=

# OPTIONAL — defaults to https://api.3common.com when unset. Override to point
# at a staging host.
# THREECOMMON_BASE_URL=https://exmaple.com

# OPTIONAL — IDs owned by the API-key host. When set, each enables the
# retrieve/read happy path for that resource; leave blank to skip those checks.
# (The comp/uncomp subscription checks need no ID — they only exercise the 404
# path with a well-formed-but-missing ObjectId.)
SMOKE_EVENT_ID=
SMOKE_INVOICE_ID=
SMOKE_SUBSCRIPTION_ID=
