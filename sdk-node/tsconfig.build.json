{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test", "examples", "**/*.test.ts", "**/*.test-d.ts"]
}
